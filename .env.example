# ============================================================================
# DogeBox Reward Tracker - Environment Configuration
# Copy this file to `.env` and fill in the values.
# ============================================================================

# --- Telegram (required) --------------------------------------------------
# Create a bot with @BotFather and paste the token it returns.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Your own Telegram user id (message @userinfobot to get it). Used only for
# optional admin alerts. Regular users do NOT need this — each user gets their
# own reports automatically. Leave blank if unsure.
TELEGRAM_CHAT_ID=

# --- Storage --------------------------------------------------------------
# SQLite database file. Relative paths are resolved from the project root.
DATABASE_PATH=database/dogebox.db

# --- Locale / scheduling --------------------------------------------------
# IANA timezone used for the epoch date and the daily scheduler.
TIMEZONE=Asia/Jakarta

# Time of day (HH:MM, 24h, in TIMEZONE) each user's daily report is pushed.
DAILY_REPORT_TIME=07:30

# --- Limits (public-bot abuse guard) --------------------------------------
# Maximum wallets a single user may monitor.
MAX_WALLETS_PER_USER=20

# --- OpenForge data source ------------------------------------------------
# Where the reward data actually lives (per-epoch merkle files). The bot
# fetches `${MERKLE_BASE_URL}/YYYY-MM-DD.json`.
MERKLE_BASE_URL=https://merkle.openforge.one

# Human-facing dashboard (used only for reference/links).
DASHBOARD_BASE_URL=https://dash.openforge.one

# On-chain token decimals used to convert cumulativeAmount (wei) -> CYS.
TOKEN_DECIMALS=18

# How many days back to search when the current epoch is not yet published.
EPOCH_LOOKBACK_DAYS=14

# HTTP request timeout in seconds.
REQUEST_TIMEOUT=20

# --- Logging --------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_DIR=logs
